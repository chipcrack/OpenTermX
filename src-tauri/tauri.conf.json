{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "OpenTermX",
  "version": "0.1.6",
  "identifier": "com.opentermx.desktop",
  "build": {
    "beforeDevCommand": "npm run dev:tauri",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "label": "main",
        "create": false,
        "title": "OpenTermX",
        "width": 1020,
        "height": 720,
        "minWidth": 852,
        "minHeight": 480,
        "center": true,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "publisher": "Angelo Lopez Torrico",
    "copyright": "Copyright © 2026 Angelo Lopez Torrico",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
     "windows": {
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "installMode": "perMachine",
        "displayLanguageSelector": true,
        "languages": ["Spanish", "English"]
      }
    }
  }
}
